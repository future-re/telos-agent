Screen {
    layout: vertical;
}

#body {
    height: 1fr;
    layout: vertical;
}

TranscriptView {
    height: 1fr;
    padding: 1 2;
}

#transcript {
    width: 100%;
}

PromptInput {
    dock: bottom;
    height: 3;
    margin: 0 1 0 1;
}

StatusBar {
    dock: bottom;
    height: 1;
    padding: 0 2;
    color: $text-muted;
    background: $surface;
}

ApprovalOverlay {
    layer: overlay;
    offset: 0 0;
    width: 40;
    height: 5;
    align: center middle;
    padding: 1 2;
    border: round $warning;
    background: $panel;
    display: none;
}
