---
import '../styles/global.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = (path: string) => `${base}${path.startsWith('/') ? path : `/${path}`}`;

const capabilities = [
  {
    label: 'Runtime',
    title: 'Agent turns without glue code',
    text: 'Model calls, tool requests, approvals, cancellation, compaction, and final responses move through one explicit loop.',
  },
  {
    label: 'Control',
    title: 'Policy before execution',
    text: 'Shell commands, files, MCP tools, plugin tools, and custom tools pass through permission and approval gates.',
  },
  {
    label: 'Extensions',
    title: 'MCP and plugin surfaces',
    text: 'Bridge MCP servers and package tools, skills, prompt sections, hooks, subagents, and marketplace metadata.',
  },
  {
    label: 'Clients',
    title: 'One core, many clients',
    text: 'Use the same Rust runtime behind the installable CLI/TUI, desktop prototype, and embedded library workflows.',
  },
];

const docs = [
  {
    label: 'Quick Start',
    text: 'Install the CLI, configure a provider, and run your first turn.',
    path: '/docs/quick-start/',
  },
  {
    label: 'Library API Guide',
    text: 'Embed telos_agent and wire your own provider and tools.',
    path: '/docs/library-api/',
  },
  {
    label: 'CLI Guide',
    text: 'Use sessions, commands, approval policies, and terminal workflows.',
    path: '/docs/cli-guide/',
  },
  {
    label: 'Configuration',
    text: 'Layer project, user, provider, and policy settings.',
    path: '/docs/configuration/',
  },
  {
    label: 'Plugins and MCP',
    text: 'Connect external tool ecosystems without changing the runtime.',
    path: '/docs/plugins-mcp/',
  },
  {
    label: 'Rust API Reference',
    text: 'Jump into generated rustdoc for exact item-level details.',
    path: '/api/rust/telos_agent/',
  },
];

const installOptions = [
  {
    label: 'Python / PyPI',
    command: 'pip install telos-cli',
    note: 'Fastest path for Python-first environments and CI images.',
  },
  {
    label: 'Rust / Cargo',
    command: 'cargo install telos-cli',
    note: 'Native Rust install for cargo-managed developer machines.',
  },
  {
    label: 'Rust library',
    command: 'cargo add telos_agent',
    note: 'Embed the runtime directly in your own Rust client.',
  },
];

const runtimeSteps = [
  ['1', 'Prompt enters the session', 'User input, context, memory, and instructions are assembled for the provider.'],
  ['2', 'Provider streams intent', 'Assistant text and tool calls arrive as typed runtime events.'],
  ['3', 'Policies decide execution', 'Tools are validated, gated by config, and routed through approvals when needed.'],
  ['4', 'Results return to the model', 'Tool output, failures, and diagnostics feed back into the same controlled loop.'],
];

const useCases = [
  'Build a CLI agent with guarded shell and file operations.',
  'Embed a turn loop inside a product client without rewriting tool plumbing.',
  'Expose MCP servers, plugin tools, and custom local tools through one registry.',
  'Ship repeatable workflows with approvals, diagnostics, and provider routing.',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="telos is a Rust agent runtime for tool execution, CLI workflows, MCP, plugins, and product clients."
    />
    <title>telos - Rust agent runtime</title>
    <link rel="icon" href={href('/favicon.svg')} />
  </head>
  <body class="landing">
    <header class="site-header">
      <a class="brand" href={href('/')} aria-label="telos home">
        <span class="brand-mark">t</span>
        <span>telos</span>
      </a>
      <nav aria-label="Primary">
        <a href={href('/docs/introduction/')}>Docs</a>
        <a href={href('/api/rust/telos_agent/')}>API</a>
        <a href={href('/docs/cli-guide/')}>CLI</a>
        <a href="https://github.com/future-re/telos-agent">GitHub</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Rust agent runtime with Python installation</p>
          <h1>Build agent clients that call tools under control.</h1>
          <p class="hero-text">
            telos packages the production shape around an agent turn: provider
            routing, streaming events, tool registries, shell policy, human
            approvals, MCP, plugins, memory, and clients you can ship.
          </p>
          <div class="hero-actions">
            <a class="button primary" href={href('/docs/quick-start/')}>Quick Start</a>
            <a class="button secondary" href={href('/docs/cli-guide/')}>Install CLI</a>
          </div>
          <div class="hero-meta" aria-label="Project highlights">
            <span>PyPI package: telos-cli</span>
            <span>Rust crate: telos_agent</span>
            <span>MCP-ready tool bridge</span>
          </div>
        </div>

        <div class="runtime-console" aria-label="Install and runtime preview">
          <div class="install-tabs">
            {installOptions.map((item) => (
              <article>
                <div class="panel-title">{item.label}</div>
                <pre><code>{item.command}</code></pre>
                <p>{item.note}</p>
              </article>
            ))}
          </div>
          <div class="terminal-panel featured">
            <div class="panel-title">Controlled tool turn</div>
            <pre><code>let mut session = AgentSession::new(config)?;
tools.register(shell_tool.with_policy(policy));

let events = session.run_turn(&provider, &tools, prompt).await?;
stream(events).with_approval_ui().await?;</code></pre>
          </div>
        </div>
      </section>

      <section class="trust-strip" aria-label="Runtime surfaces">
        <span>CLI / TUI</span>
        <span>Rust library</span>
        <span>Desktop client</span>
        <span>MCP bridge</span>
        <span>Plugin registry</span>
      </section>

      <section class="capabilities" aria-label="Capabilities">
        {capabilities.map((item) => (
          <article>
            <p>{item.label}</p>
            <h2>{item.title}</h2>
            <p>{item.text}</p>
          </article>
        ))}
      </section>

      <section class="architecture-section">
        <div>
          <p class="eyebrow">Architecture</p>
          <h2>One runtime boundary around model output and side effects.</h2>
          <p>
            telos treats tool execution as a first-class part of the turn, not a
            callback hidden in application glue. That gives clients a stable place
            to add policy, logging, approvals, diagnostics, and recovery.
          </p>
        </div>
        <ol class="runtime-steps">
          {runtimeSteps.map(([number, title, text]) => (
            <li>
              <span>{number}</span>
              <div>
                <h3>{title}</h3>
                <p>{text}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <section class="workflow-section" aria-label="Workflow examples">
        <div class="workflow-copy">
          <p class="eyebrow">Operational fit</p>
          <h2>Designed for agents that need to touch real systems.</h2>
        </div>
        <div class="use-case-grid">
          {useCases.map((item) => (
            <article>
              <span></span>
              <p>{item}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="code-section" aria-label="CLI and library examples">
        <div class="terminal-panel">
          <div class="panel-title">CLI from Python packaging</div>
          <pre><code>pip install telos-cli
telos --help
telos "inspect this repository and suggest the next task"</code></pre>
        </div>
        <div class="terminal-panel">
          <div class="panel-title">Library integration</div>
          <pre><code>cargo add telos_agent

let tools = ToolRegistry::default();
let response = session.run_turn(&provider, &tools, prompt).await?;</code></pre>
        </div>
      </section>

      <section class="docs-grid">
        <div>
          <p class="eyebrow">Documentation</p>
          <h2>Start with workflows, then drop into exact API details.</h2>
          <p>
            The guides cover installation, CLI usage, configuration, plugins, MCP,
            deployment, and the Rust library surface.
          </p>
        </div>
        <div class="doc-links">
          {docs.map((item) => (
            <a href={href(item.path)}>
              <strong>{item.label}</strong>
              <span>{item.text}</span>
            </a>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>
